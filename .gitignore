# ── PlatformIO / ESP-IDF build output (large, regenerated on build) ──
.pio/
build/
*.bin
*.elf
*.map

# Generated sdkconfig (keep sdkconfig.defaults, which holds our settings)
sdkconfig
sdkconfig.old
sdkconfig.*
!sdkconfig.defaults

# managed_components/ is fetched by the IDF component manager and then patched at
# build time by shared/patch_components.py, so it's regenerated — not committed.
# (dependencies.lock IS committed, to pin the component versions.)
managed_components/

# ── Python (used by the dump/seed helper scripts, if any) ──
__pycache__/
*.pyc
.venv/

# ── IDE / OS junk ──
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
