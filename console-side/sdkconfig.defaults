# Console on UART0 (native USB is the emulated portal device once TinyUSB starts).
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# 16 MB flash, no PSRAM (matches our boards; avoids octal-PSRAM init crash).
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_SPIRAM=n

CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_FREERTOS_HZ=1000

# TinyUSB: one HID interface, big enough buffer for the 32-byte portal reports.
CONFIG_TINYUSB_HID_COUNT=1
CONFIG_TINYUSB_HID_BUFSIZE=64
